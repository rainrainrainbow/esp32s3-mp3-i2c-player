# PSRAM完全禁用 - 只使用内部RAM
CONFIG_SPIRAM=n
CONFIG_ESP32S3_SPIRAM_SUPPORT=n
CONFIG_SPIRAM_BOOT_INIT=n
CONFIG_SPIRAM_ALLOW_BSS_SEG_EXTERNAL_MEMORY=n
CONFIG_SPIRAM_ALLOW_STACK_EXTERNAL_MEMORY=n
CONFIG_SPIRAM_CACHE_WORKAROUND=n
CONFIG_SPIRAM_IGNORE_NOTFOUND=n
CONFIG_ESP32S3_DEFAULT_CPU_FREQ_240=y
CONFIG_ESP_TASK_WDT=n
CONFIG_ESP_TASK_WDT_PANIC=n
CONFIG_INT_WDT=n
CONFIG_INT_WDT_TIMEOUT_MS=0
CONFIG_ESP_COREDUMP_ENABLE=n
